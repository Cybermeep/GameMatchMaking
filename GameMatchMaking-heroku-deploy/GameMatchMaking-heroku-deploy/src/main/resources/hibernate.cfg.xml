<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.7//EN"
        "http://www.hibernate.org/dtd/hibernate-configuration-3.7.dtd">
<hibernate-configuration>
	<session-factory>
		<!-- These values are overridden at runtime by HibernateUtil via environment variables.
             The values here are safe fallback placeholders only. -->
		<property name="hibernate.dialect">org.hibernate.dialect.Oracle12cDialect</property>
		<property name="hibernate.connection.driver_class">oracle.jdbc.OracleDriver</property>
		<property name="hibernate.connection.url">jdbc:oracle:thin:@localhost:1521:ORCL</property>
		<property name="hibernate.connection.username">IT326S11</property>
		<property name="hibernate.connection.password">website50</property>

		<!-- Connection pool settings -->
		<property name="hibernate.c3p0.min_size">2</property>
		<property name="hibernate.c3p0.max_size">10</property>
		<property name="hibernate.c3p0.timeout">300</property>
		<property name="hibernate.c3p0.max_statements">50</property>
		<property name="hibernate.c3p0.idle_test_period">3000</property>

		<!-- Hibernate properties -->
		<!-- "update" means Hibernate will create tables that don't exist and
             add columns that are missing, but won't delete existing data. -->
		<property name="hibernate.hbm2ddl.auto">update</property>
		<property name="hibernate.show_sql">false</property>
		<property name="hibernate.format_sql">false</property>

		<!-- Entity mappings — every @Entity class must be listed here -->
		<mapping class="edu.isu.gamematch.User"/>
		<mapping class="edu.isu.gamematch.Game"/>
		<mapping class="edu.isu.gamematch.Group"/>
		<mapping class="edu.isu.gamematch.GameAchievement"/>
		<mapping class="edu.isu.gamematch.Achievement"/>
		<mapping class="edu.isu.gamematch.Tag"/>
		<mapping class="edu.isu.gamematch.GroupVote"/>
		<mapping class="edu.isu.gamematch.UserProfile"/>
		<mapping class="edu.isu.gamematch.GroupSession"/>
		<mapping class="edu.isu.gamematch.JoinRequest"/>
		<mapping class="edu.isu.gamematch.UserGame"/>
	</session-factory>
</hibernate-configuration>