package edu.isu.gamematch;
import org.hibernate.Session;
import org.hibernate.SessionFactory;
import org.hibernate.Transaction;
import org.hibernate.cfg.Configuration;
import java.util.List;
import java.util.Map;

public class SQLHandler extends DataHandler {
    private SessionFactory sessionFactory;
    private Configuration configuration;

    // Constructor matching DataHandler
    public SQLHandler(String serverName, String username, String password) {
        super(serverName, username, password);
        initializeHibernate(serverName, username, password);
    }

    // Alternative constructor with port
    public SQLHandler(String serverName, int port, String username, String password) {
        super(serverName, username, password);
        initializeHibernateWithPort(serverName, port, username, password);
    }

    private void initializeHibernate(String serverName, String username, String password) {
        try {
            configuration = new Configuration();
            configuration.configure("hibernate.cfg.xml");

            // Set database connection properties
            configuration.setProperty("hibernate.connection.url",
                "jdbc:mysql://" + serverName + "/gamematchmaking");
            configuration.setProperty("hibernate.connection.username", username);
            configuration.setProperty("hibernate.connection.password", password);

            // Add entity classes
            configuration.addAnnotatedClass(User.class);
            configuration.addAnnotatedClass(Game.class);
            configuration.addAnnotatedClass(Group.class);
            configuration.addAnnotatedClass(GroupSession.class);
            configuration.addAnnotatedClass(Tag.class);
            configuration.addAnnotatedClass(Achievement.class);
            configuration.addAnnotatedClass(GameAchievement.class);

            sessionFactory = configuration.buildSessionFactory();
        } catch (Exception e) {
            System.err.println("Failed to initialize Hibernate: " + e.getMessage());
            throw new RuntimeException("Hibernate initialization failed", e);
        }
    }

    private void initializeHibernateWithPort(String serverName, int port, String username, String password) {
        try {
            configuration = new Configuration();
            configuration.configure("hibernate.cfg.xml");

            // Set database connection properties with port
            configuration.setProperty("hibernate.connection.url",
                "jdbc:mysql://" + serverName + ":" + port + "/gamematchmaking");
            configuration.setProperty("hibernate.connection.username", username);
            configuration.setProperty("hibernate.connection.password", password);

            // Add entity classes
            configuration.addAnnotatedClass(User.class);
            configuration.addAnnotatedClass(Game.class);
            configuration.addAnnotatedClass(Group.class);
            configuration.addAnnotatedClass(GroupSession.class);
            configuration.addAnnotatedClass(Tag.class);
            configuration.addAnnotatedClass(Achievement.class);
            configuration.addAnnotatedClass(GameAchievement.class);

            sessionFactory = configuration.buildSessionFactory();
        } catch (Exception e) {
            System.err.println("Failed to initialize Hibernate: " + e.getMessage());
            throw new RuntimeException("Hibernate initialization failed", e);
        }
    }

    // Override DataHandler methods with Hibernate implementations
    @Override
    public boolean beginConnection() {
        if (sessionFactory == null || sessionFactory.isClosed()) {
            initializeHibernate(getServerName(), getUsername(), getPassword());
        }
        return sessionFactory != null && !sessionFactory.isClosed();
    }

    @Override
    public boolean endConnection() {
        if (sessionFactory != null && !sessionFactory.isClosed()) {
            sessionFactory.close();
            return true;
        }
        return false;
    }

    @Override
    public boolean read() {
        // Example: Read all users
        try (Session session = sessionFactory.openSession()) {
            CriteriaBuilder cb = session.getCriteriaBuilder();
            CriteriaQuery<User> cq = cb.createQuery(User.class);
            Root<User> root = cq.from(User.class);
            cq.select(root);

            Query<User> query = session.createQuery(cq);
            List<User> users = query.getResultList();
            System.out.println("Read " + users.size() + " users from database");
            return true;
        } catch (Exception e) {
            System.err.println("Error reading data: " + e.getMessage());
            return false;
        }
    }

    @Override
    public boolean passData(Map<String, Object> data) {
        // Save data to database using Hibernate
        try (Session session = sessionFactory.openSession()) {
            Transaction tx = session.beginTransaction();

            // Example: Save User from Map data
            if (data.containsKey("entityType") && "User".equals(data.get("entityType"))) {
                User user = new User();
                user.setId((String) data.get("id"));
                user.setProfileName((String) data.get("profileName"));
                session.persist(user);
            }

            tx.commit();
            System.out.println("Data passed to database successfully");
            return true;
        } catch (Exception e) {
            System.err.println("Error passing data: " + e.getMessage());
            return false;
        }
    }

    @Override
    public boolean remove() {
        // Example: Remove all users (use with caution!)
        try (Session session = sessionFactory.openSession()) {
            Transaction tx = session.beginTransaction();
            Query<?> query = session.createQuery("DELETE FROM User");
            int deletedCount = query.executeUpdate();
            tx.commit();
            System.out.println("Removed " + deletedCount + " users from database");
            return true;
        } catch (Exception e) {
            System.err.println("Error removing data: " + e.getMessage());
            return false;
        }
    }

    @Override
    public boolean write() {
        // Example: Write a test user
        try (Session session = sessionFactory.openSession()) {
            Transaction tx = session.beginTransaction();

            User testUser = new User("test-id", "test-profile");
            session.persist(testUser);

            tx.commit();
            System.out.println("Test user written to database");
            return true;
        } catch (Exception e) {
            System.err.println("Error writing data: " + e.getMessage());
            return false;
        }
    }

    // User management methods with Hibernate implementations
    @Override
    public boolean createUser() {
        try (Session session = sessionFactory.openSession()) {
            Transaction tx = session.beginTransaction();

            User newUser = new User();
            newUser.setId("user-" + System.currentTimeMillis());
            newUser.setProfileName("New User");
            session.persist(newUser);

            tx.commit();
            System.out.println("Created new user: " + newUser.getId());
            return true;
        } catch (Exception e) {
            System.err.println("Error creating user: " + e.getMessage());
            return false;
        }
    }

    @Override
    public boolean updateUsers() {
        try (Session session = sessionFactory.openSession()) {
            Transaction tx = session.beginTransaction();

            // Update all users' profile names
            Query<User> query = session.createQuery("FROM User", User.class);
            List<User> users = query.getResultList();

            for (User user : users) {
                user.setProfileName(user.getProfileName() + "-updated");
                session.merge(user);
            }

            tx.commit();
            System.out.println("Updated " + users.size() + " users");
            return true;
        } catch (Exception e) {
            System.err.println("Error updating users: " + e.getMessage());
            return false;
        }
    }

    @Override
    public User removeUsers() {
        try (Session session = sessionFactory.openSession()) {
            Transaction tx = session.beginTransaction();

            // Get and remove the first user
            Query<User> query = session.createQuery("FROM User WHERE profileName = :name", User.class);
            query.setParameter("name", "default");
            User userToRemove = query.uniqueResult();

            if (userToRemove != null) {
                session.remove(userToRemove);
            }

            tx.commit();
            System.out.println("Removed user: " + (userToRemove != null ? userToRemove.getId() : "none"));
            return userToRemove;
        } catch (Exception e) {
            System.err.println("Error removing users: " + e.getMessage());
            return null;
        }
    }

    @Override
    public User searchUser(String profileName) {
        try (Session session = sessionFactory.openSession()) {
            Query<User> query = session.createQuery("FROM User WHERE profileName = :name", User.class);
            query.setParameter("name", profileName);
            User user = query.uniqueResult();

            System.out.println("Search result for '" + profileName + "': " +
                (user != null ? "found" : "not found"));
            return user;
        } catch (Exception e) {
            System.err.println("Error searching user: " + e.getMessage());
            return null;
        }
    }

    @Override
    public String generateActivitySummary() {
        try (Session session = sessionFactory.openSession()) {
            // Count total users
            Query<Long> userCountQuery = session.createQuery("SELECT COUNT(*) FROM User", Long.class);
            Long userCount = userCountQuery.uniqueResult();

            // Count total games
            Query<Long> gameCountQuery = session.createQuery("SELECT COUNT(*) FROM Game", Long.class);
            Long gameCount = gameCountQuery.uniqueResult();

            // Count total groups
            Query<Long> groupCountQuery = session.createQuery("SELECT COUNT(*) FROM Group", Long.class);
            Long groupCount = groupCountQuery.uniqueResult();

            String summary = String.format(
                "Activity Summary for %s:\n" +
                "Total Users: %d\n" +
                "Total Games: %d\n" +
                "Total Groups: %d\n" +
                "Generated at: %s",
                getServerName(),
                userCount != null ? userCount : 0,
                gameCount != null ? gameCount : 0,
                groupCount != null ? groupCount : 0,
                new java.util.Date()
            );

            System.out.println("Generated activity summary");
            return summary;
        } catch (Exception e) {
            System.err.println("Error generating activity summary: " + e.getMessage());
            return "Error generating activity summary: " + e.getMessage();
        }
    }

    // Additional Hibernate-specific methods
    public <T> T findById(Class<T> entityClass, Object id) {
        try (Session session = sessionFactory.openSession()) {
            return session.get(entityClass, id);
        }
    }

    public <T> List<T> findAll(Class<T> entityClass) {
        try (Session session = sessionFactory.openSession()) {
            CriteriaBuilder cb = session.getCriteriaBuilder();
            CriteriaQuery<T> cq = cb.createQuery(entityClass);
            Root<T> root = cq.from(entityClass);
            cq.select(root);

            Query<T> query = session.createQuery(cq);
            return query.getResultList();
        }
    }

    public <T> void saveOrUpdate(T entity) {
        try (Session session = sessionFactory.openSession()) {
            Transaction tx = session.beginTransaction();
            session.saveOrUpdate(entity);
            tx.commit();
        }
    }

    public <T> void delete(T entity) {
        try (Session session = sessionFactory.openSession()) {
            Transaction tx = session.beginTransaction();
            session.remove(entity);
            tx.commit();
        }
    }

    public Session getSession() {
        return sessionFactory.openSession();
    }

    public SessionFactory getSessionFactory() {
        return sessionFactory;
    }

    public void close() {
        if (sessionFactory != null && !sessionFactory.isClosed()) {
            sessionFactory.close();
        }
    }
}